{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/cybersecurity-playbook/detection-validation-v1.schema.json",
  "title": "Sanitized Detection Validation Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "validation_run_id",
    "detection_id",
    "scenario_id",
    "technique_id",
    "status",
    "validation_environment",
    "validated_at",
    "source_record_sha256",
    "positive_test",
    "variant_test",
    "negative_tests",
    "cleanup",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "validation_run_id": { "type": "string", "pattern": "^VAL-\\d{4}-\\d{3}$" },
    "detection_id": { "type": "string", "pattern": "^DET-\\d{4}-\\d{3}$" },
    "scenario_id": { "type": "string", "pattern": "^PT-\\d{4}-\\d{3}$" },
    "technique_id": { "type": "string", "pattern": "^T\\d{4}(\\.\\d{3})?$" },
    "status": { "const": "historical-live-validated" },
    "validation_environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_role", "siem_role", "sanitized"],
      "properties": {
        "target_role": { "const": "authorized lab endpoint" },
        "siem_role": { "const": "internal SIEM service" },
        "sanitized": { "const": true }
      }
    },
    "validated_at": { "type": "string", "format": "date-time" },
    "source_record_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "positive_test": { "$ref": "#/$defs/testResult" },
    "variant_test": { "$ref": "#/$defs/testResult" },
    "negative_tests": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/negativeResult" }
    },
    "cleanup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "confirmed_at"],
      "properties": {
        "status": { "enum": ["confirmed", "failed", "unknown"] },
        "confirmed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    }
  },
  "$defs": {
    "testResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detection_fired", "marker_found", "latency_seconds", "latency_status"],
      "properties": {
        "detection_fired": { "type": "boolean" },
        "marker_found": { "type": ["boolean", "null"] },
        "latency_seconds": { "type": ["number", "null"], "minimum": 0 },
        "latency_status": { "enum": ["measured", "uncomputed", "not-applicable"] }
      }
    },
    "negativeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ordinal", "detection_fired", "expected_quiet"],
      "properties": {
        "ordinal": { "type": "integer", "minimum": 1 },
        "detection_fired": { "type": "boolean" },
        "expected_quiet": { "type": "boolean" }
      }
    }
  }
}
