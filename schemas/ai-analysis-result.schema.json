{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Analysis Result",
  "type": "object",
  "required": [
    "executive_summary",
    "confirmed_observations",
    "candidate_findings",
    "candidate_attack_mappings",
    "scope_questions",
    "recommended_hunts",
    "recommended_collections",
    "detection_opportunities",
    "missing_evidence",
    "unsupported_assumptions",
    "confidence"
  ],
  "properties": {
    "executive_summary": {
      "type": "string"
    },
    "confirmed_observations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidate_attack_mappings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_hunts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_collections": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "detection_opportunities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unsupported_assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
