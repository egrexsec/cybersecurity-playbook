{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/cybersecurity-playbook/live-preflight-v1.schema.json",
  "title": "Authorized Live Validation Preflight",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "target_role",
    "authorized",
    "identity_verified",
    "dns_healthy",
    "time_synchronized",
    "storage_healthy",
    "telemetry_healthy",
    "rollback_snapshot_confirmed",
    "expected_telemetry",
    "cleanup_steps",
    "validated_at",
    "expires_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "scenario_id": { "type": "string", "pattern": "^PT-\\d{4}-\\d{3}$" },
    "target_role": {
      "enum": ["authorized lab endpoint", "designated CTI host", "internal SIEM service", "DFIR workstation"]
    },
    "authorized": { "const": true },
    "identity_verified": { "const": true },
    "dns_healthy": { "const": true },
    "time_synchronized": { "const": true },
    "storage_healthy": { "const": true },
    "telemetry_healthy": { "const": true },
    "rollback_snapshot_confirmed": { "const": true },
    "expected_telemetry": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "cleanup_steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },
    "validated_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string", "maxLength": 2000 }
  }
}
