{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tool Execution Result",
  "type": "object",
  "required": [
    "tool",
    "command",
    "started_at",
    "ended_at",
    "exit_code",
    "stdout_path",
    "stderr_path"
  ],
  "properties": {
    "tool": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "stdout_path": {
      "type": "string"
    },
    "stderr_path": {
      "type": "string"
    }
  }
}
