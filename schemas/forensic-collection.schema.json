{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forensic Collection",
  "type": "object",
  "required": [
    "case_id",
    "profile",
    "target",
    "collector",
    "tool_version",
    "started_at",
    "completed_at",
    "files",
    "hashes",
    "errors",
    "status"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^(IR|HUNT|DFIR|PT|DET|VAL)-\\d{4}-\\d{3}$"
    },
    "profile": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "collector": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hashes": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    }
  }
}
