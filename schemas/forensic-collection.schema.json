{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Forensic Collection",
  "type": "object",
  "required": [
    "case_id",
    "profile",
    "target",
    "collector",
    "tool_version",
    "started_at",
    "completed_at",
    "files",
    "hashes",
    "errors",
    "status",
    "evidence_class",
    "artifacts"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "pattern": "^(IR|HUNT|DFIR|PT|DET|VAL)-\\d{4}-(\\d{3}|[A-F0-9]{12})$"
    },
    "profile": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "collector": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hashes": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "planned",
        "fixture-collected",
        "live-collected",
        "partially-collected",
        "collection-failed"
      ]
    },
    "evidence_class": {
      "enum": [
        "plan",
        "fixture",
        "live"
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "status",
          "sha256",
          "error"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "status": {
            "enum": [
              "not-collected",
              "collected",
              "absent",
              "collection-failed"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^$|^[a-f0-9]{64}$"
          },
          "error": {
            "type": "string"
          }
        },
        "anyOf": [
          {
            "required": [
              "name"
            ]
          },
          {
            "required": [
              "path"
            ]
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
