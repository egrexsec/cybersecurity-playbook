{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Investigation Case",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "status",
    "severity",
    "confidence",
    "created_at",
    "updated_at",
    "owner",
    "source",
    "scope",
    "attack_mapping",
    "automation",
    "evidence",
    "detections",
    "approvals",
    "conclusion"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(IR|HUNT|DFIR|PT|DET|VAL)-\\d{4}-\\d{3}$"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "enum": [
        "incident",
        "hunt",
        "dfir",
        "purple-team",
        "detection",
        "validation"
      ]
    },
    "status": {
      "enum": [
        "new",
        "triage",
        "enrichment",
        "collection",
        "hunting",
        "analysis",
        "reporting",
        "awaiting-approval",
        "closed"
      ]
    },
    "severity": {
      "enum": [
        "informational",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "source": {
      "type": "object",
      "required": [
        "platform"
      ],
      "properties": {
        "platform": {
          "type": "string"
        },
        "alert_name": {
          "type": "string"
        },
        "rule_id": {
          "type": "string"
        },
        "event_time": {
          "type": "string"
        },
        "original_reference": {
          "type": "string"
        }
      }
    },
    "scope": {
      "type": "object",
      "properties": {
        "hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "users": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "processes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "attack_mapping": {
      "type": "object",
      "properties": {
        "technique_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "automation": {
      "type": "object",
      "properties": {
        "intake_complete": {
          "type": "boolean"
        },
        "enrichment_complete": {
          "type": "boolean"
        },
        "collection_complete": {
          "type": "boolean"
        },
        "hunting_complete": {
          "type": "boolean"
        },
        "timeline_complete": {
          "type": "boolean"
        },
        "analysis_complete": {
          "type": "boolean"
        },
        "detection_review_complete": {
          "type": "boolean"
        },
        "containment_plan_complete": {
          "type": "boolean"
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "manifest": {
          "type": "string"
        },
        "raw_location": {
          "type": "string"
        },
        "processed_location": {
          "type": "string"
        },
        "hashes": {
          "type": "object"
        }
      }
    },
    "detections": {
      "type": "object",
      "properties": {
        "triggered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "improved": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validation_runs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approvals": {
      "type": "object",
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "completed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "conclusion": {
      "type": "object",
      "properties": {
        "disposition": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "score": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
