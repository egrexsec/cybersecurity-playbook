any where (process.executable:"*\\reg.exe" and (process.command_line:"*CurrentVersion*" and process.command_line:"*Run*" and process.command_line:"*cmd.exe*" and process.command_line:"*Temp*")) or (process.executable:"*\\powershell.exe" and (process.command_line:"*Set-ItemProperty*" and process.command_line:"*CurrentVersion*" and process.command_line:"*Run*" and process.command_line:"*powershell.exe*" and process.command_line:"*Temp*"))