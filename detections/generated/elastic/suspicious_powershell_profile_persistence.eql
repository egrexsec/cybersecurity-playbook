any where process.executable:"*\\powershell.exe" and (process.command_line like~ ("*$PROFILE*", "*profile.ps1*")) and (process.command_line like~ ("*Add-Content*", "*Set-Content*", "*Out-File*", "*>>*")) and (process.command_line like~ ("*Set-Content*", "*Invoke-Expression*", "*FromBase64String*", "*$payload*", "*DownloadString*", "*Start-Process*", "*Net.WebClient*"))