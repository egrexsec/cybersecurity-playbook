<!-- PT-2026-003 test-scope rules -->
<group name="local,windows,wmi,pt2026003,">
  <rule id="100205" level="12">
    <if_sid>91816</if_sid>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)\[wmiclass\].*Win32_Process.*pt-2026-003-wmic-positive\.txt</field>
    <description>PT-2026-003 WMI initiation via [wmiclass] PowerShell detected</description>
    <group>attack.execution,attack.t1047,attack.t1059.001,</group>
  </rule>

  <rule id="100206" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)\\cmd\.exe</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\WmiPrvSE\.exe</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)pt-2026-003-invoke-wmi-positive\.txt</field>
    <description>PT-2026-003 WMI local process creation via Invoke-WmiMethod detected</description>
    <group>attack.execution,attack.t1047,attack.t1059.003,attack.t1059.001,</group>
  </rule>
</group>
