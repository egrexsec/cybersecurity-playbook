# Copy to /opt/opencti/.env and set mode 0600. Never commit the runtime file.
# Keep public defaults loopback-only. Set an approved lab interface in the
# private runtime environment when remote lab access is required.
OPENCTI_BIND_IP=127.0.0.1
OPENCTI_BASE_URL=http://127.0.0.1:8080
OPENCTI_ADMIN_EMAIL=admin@example.invalid
OPENCTI_ADMIN_PASSWORD=replace-with-a-long-random-password
OPENCTI_ADMIN_TOKEN=replace-with-a-random-uuid
OPENCTI_ENCRYPTION_KEY=replace-with-at-least-32-random-bytes
OPENCTI_HEALTHCHECK_ACCESS_KEY=replace-with-a-random-health-key
MINIO_ROOT_USER=replace-with-a-random-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password
RABBITMQ_DEFAULT_USER=replace-with-a-random-user
RABBITMQ_DEFAULT_PASS=replace-with-a-long-random-password
SHODAN_CONNECTOR_ID=replace-with-a-random-uuid
SHODAN_TOKEN=replace-with-the-runtime-shodan-api-key
